{
  "name": "zeta.js",
  "version": "0.1.1",
  "description": "The Universal Web Drawing Engine — declarative, reactive, renderer-agnostic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "canvas",
    "svg",
    "diagram",
    "graphics",
    "scene-graph",
    "visualization",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhilmitrax/Zeta.js.git"
  },
  "homepage": "https://github.com/nikhilmitrax/Zeta.js#readme",
  "bugs": {
    "url": "https://github.com/nikhilmitrax/Zeta.js/issues"
  },
  "scripts": {
    "build": "tsup",
    "build:demo": "vite build demo --config demo/vite.config.ts",
    "dev": "vite demo",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build && npm run build:demo",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
